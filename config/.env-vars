export API_PARALLEL_TEST_CONCURRENCY=7

export PA="$HOME/Coding/personalAutomation"

export CONFIG="$PA/config"
export OUTPUTS="$PA/outputs"
export SCRIPTS="$PA/scripts"

# Add RVM to PATH for scripting.
export PATH="$PATH:$HOME/.rvm/bin"

# Add Applications to PATH
export PATH="$PATH:/Applications"
# pnpm
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

export PATH="$HOME/.local/bin:$HOME/Library/Application Support/fnm:$PATH"

export KUBE_EDITOR='code --wait'

# export AWS_PROFILE=dojo-dev

export TZ='Etc/UTC'

export PKG_CONFIG_PATH="/opt/homebrew/opt/mysql-client/lib/pkgconfig:$PKG_CONFIG_PATH"

export WEB_MONOREPO_PATH="$HOME/Coding/work/web-monorepo"